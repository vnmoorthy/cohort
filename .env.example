# Cohort — sponsor integration keys.
# Every integration runs on a LOCAL FALLBACK when its key is absent, so the app
# works end-to-end with zero keys. Drop a key in to upgrade that layer to the
# real sponsor API. Copy this file to .env.local and fill in what you have.

# You.com — Research / Search API (prevalence + investigator enrichment)
YOUCOM_API_KEY=

# Nimble — web-data agents (competitive trial landscape + site enrichment)
NIMBLE_API_KEY=

# Hydra DB — versioned, time-aware context ledger (audit trail + site history)
HYDRA_API_KEY=
HYDRA_BASE_URL=

# BAND — human-in-the-loop approval + multi-agent coordination
BAND_API_KEY=
# BAND_CREW_JSON — (deploy only) contents of .cohort/band-crew.json so a deployed
# instance reuses the registered crew instead of re-registering
BAND_CREW_JSON=

# AgentOS / AgentHog — agent-run observability & tracing (agops_ key)
AGENTOS_API_KEY=
AGENTOS_ENDPOINT=

# InsForge — agent-native backend (persistence + hosting)
INSFORGE_API_KEY=
INSFORGE_PROJECT_URL=
